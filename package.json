{
  "name": "qa-agent",
  "version": "1.0.0",
  "description": "Intelligent QA agent that analyzes any codebase and generates an optimal test suite",
  "type": "module",
  "bin": {
    "qa-agent": "./dist/bin/qa-agent.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node --esm src/bin/qa-agent.ts",
    "start": "node dist/bin/qa-agent.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@supabase/supabase-js": "^2.43.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "handlebars": "^4.7.8",
    "openai": "^4.47.0",
    "ora": "^8.1.0",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@vitest/coverage-v8": "^1.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["qa", "testing", "ai", "cli", "code-analysis"],
  "license": "MIT"
}
